# Database connection string (PostgreSQL)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:password@localhost:5432/tickit?schema=public"

# Authentication (To be used in Step 2)
JWT_SECRET="your_very_secret_key_here"

# Google OAuth (To be used in Step 3)
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"
GOOGLE_CALLBACK_URL="http://localhost:3000/auth/google/callback"

# CORS Allowed Origins (Comma separated for multiple values)
ALLOWED_ORIGINS="http://localhost:5173"
